# ===========================
# Samadhan Portal — Environment Variables
# Copy this file to backend/.env and fill in your values
# ===========================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/samadhan-portal

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Email (Nodemailer — Gmail App Password)
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

# Gemini AI (for chatbot, rephrase, translate features)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend Deployment (for Vercel)
VITE_API_URL=https://your-backend-app.onrender.com

# Backend CORS Configuration (comma separated)
CORS_ORIGIN=https://your-frontend-app.vercel.app,http://localhost:8080,http://localhost:5173
